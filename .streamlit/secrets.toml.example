# Copy this file to .streamlit/secrets.toml and fill in values.
# On Streamlit Community Cloud, enter these as secrets in the dashboard instead.
#
# Generate APP_PASSWORD_HASH:
#   python -c "import hashlib; print(hashlib.sha256(b'yourpassword').hexdigest())"
#
# Leave APP_PASSWORD_HASH empty or omit it to run without a password (local dev).

APP_PASSWORD_HASH = ""

OPENAI_API_KEY = "sk-..."
OPENAI_PRIMARY_MODEL = "gpt-4o"
OPENAI_FALLBACK_MODEL = "gpt-4o-mini"

# LangSmith tracing (optional — omit to disable)
# LANGCHAIN_API_KEY = "lsv2_..."
# LANGCHAIN_TRACING_V2 = "true"
# LANGCHAIN_PROJECT = "site-audit-agent"
